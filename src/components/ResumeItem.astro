---
import LinkOrText from './LinkOrText.astro';

const { name, location = '', title = '', date = '', roles: rolesProp, href = '' } = Astro.props;
const roles = rolesProp ?? [{ title, date }];
---
<article class="resume-item">
  <h3 class="resume-item--name resume-item--first">
    <LinkOrText href={href} text={name} />
  </h3>
  <div class="resume-item--location resume-item--second">{location}</div>
  {roles.map((role: { title: string; date: string }) => (
    <div class="resume-item--role">
      <div class="resume-item--title resume-item--first">{role.title}</div>
      <div class="resume-item--date resume-item--second">{role.date}</div>
    </div>
  ))}
  {Astro.slots.has('default') && (
    <div class="resume-item--text">
      <slot />
    </div>
  )}
</article>

<style lang="scss">
.resume-item {
  margin-bottom: 2em;

  @media (min-width: 620px) {
    &--role,
    & {
      width: 100%;
      display: flex;
      flex-wrap: wrap;
      align-items: flex-end;
    }

    &--first {
      width: 70%;
    }

    &--second {
      width: 30%;
      text-align: right;
    }
  }

  &--title {
    font-style: italic;
  }

  &--role,
  &--text {
    padding-left: 1em;
  }

  &--text {
    margin-top: 0.5em;
  }

  @media print {
    margin-bottom: 12px;
    page-break-inside: avoid;

    &,
    &--role {
      &:before,
      &:after {
        content: ' ';
        display: table;
      }

      &:after {
        clear: both;
      }
    }

    &--first,
    &--second {
      float: left;
      width: 70%;
    }
    &--second {
      width: 30%;
      float: right;
      text-align: right;
    }

    &--text {
      width: 100%;
      margin-top: 0;
    }
  }
}
</style>
